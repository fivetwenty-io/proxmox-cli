#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""Destructive VM + container lifecycle suite against a configured context.

Provisions an isolated `pvecli` SDN (zone/vnet/subnet) and a `pve-cli` resource
pool, then runs a throwaway QEMU VM and an LXC container through their full
create→start→snapshot→stop→delete lifecycle, then tears everything down. Every
resource is tagged `pve-cli`, placed in the `pve-cli` pool, and attached to the
isolated SDN — off the host management network — so other lab efforts are never
disturbed. Teardown always runs (finally), and a crashed prior run is swept
clean before the next provisions.

Usage:
  scripts/lifecycle                 # full VM + CT lifecycle against `lab`
  scripts/lifecycle --context prod
  scripts/lifecycle --vm-only       # skip the container lifecycle
  scripts/lifecycle --ct-only       # skip the VM lifecycle
  scripts/lifecycle --strict        # fail (not skip) if context is unconfigured
"""

from __future__ import annotations

import argparse
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from e2e_lib import lifecycle  # noqa: E402


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="lifecycle",
        description="Destructive VM + container lifecycle suite (isolated SDN + pool).",
    )
    parser.add_argument("--context", "-c", default=os.environ.get("PVE_E2E_CONTEXT", "lab"),
                        help="configured context name (default: lab, or $PVE_E2E_CONTEXT)")
    parser.add_argument("--binary", help="path to the pve binary (default: ./dist/pve)")
    parser.add_argument("--no-build", action="store_true",
                        help="do not auto-build the binary if ./dist/pve is missing")
    parser.add_argument("--strict", action="store_true",
                        help="exit non-zero if the context is not configured (default: skip)")
    parser.add_argument("--vm-only", action="store_true", help="run only the VM lifecycle")
    parser.add_argument("--ct-only", action="store_true", help="run only the container lifecycle")
    args = parser.parse_args()

    if args.vm_only and args.ct_only:
        parser.error("--vm-only and --ct-only are mutually exclusive")

    rc = lifecycle.run(
        context=args.context,
        binary=args.binary,
        build=not args.no_build,
        strict=args.strict,
        skip_ct=args.vm_only,
        skip_vm=args.ct_only,
    )
    sys.exit(rc)


if __name__ == "__main__":
    main()
