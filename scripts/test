#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""Dispatch test runs by tier: unit | integration | e2e | lifecycle."""

import argparse
import os
import subprocess
import sys


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def check_go() -> None:
    result = subprocess.run(["go", "version"], capture_output=True)
    if result.returncode != 0:
        die("'go' not found in PATH — install Go 1.26+")


def env_test_available() -> bool:
    """Return True if PVE_TEST_HOST is set or config/.env.test exists."""
    if os.environ.get("PVE_TEST_HOST"):
        return True
    env_file = os.path.join(os.getcwd(), "config", ".env.test")
    return os.path.isfile(env_file)


def load_env_test() -> None:
    """Load config/.env.test into the environment if present."""
    env_file = os.path.join(os.getcwd(), "config", ".env.test")
    if not os.path.isfile(env_file):
        return
    with open(env_file) as fh:
        for line in fh:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if "=" in line:
                key, _, val = line.partition("=")
                os.environ.setdefault(key.strip(), val.strip())


def run_unit(race: bool, verbose: bool) -> int:
    cmd = ["go", "test"]
    if race:
        cmd.append("-race")
    if verbose:
        cmd.append("-v")
    cmd += ["./..."]
    print(f"test/unit: {'race ' if race else ''}running go test ./...")
    result = subprocess.run(cmd)
    return result.returncode


def run_integration(verbose: bool) -> int:
    if not env_test_available():
        print(
            "test/integration: skipping — no PVE_TEST_HOST env var and no config/.env.test",
            flush=True,
        )
        print(
            "  Set PVE_TEST_HOST, PVE_TEST_USER, PVE_TEST_PASSWORD (or populate config/.env.test) to enable."
        )
        return 0
    load_env_test()
    cmd = ["go", "test", "-tags", "integration"]
    if verbose:
        cmd.append("-v")
    cmd += ["./..."]
    print("test/integration: running go test -tags integration ./...")
    result = subprocess.run(cmd)
    return result.returncode


def run_e2e(verbose: bool, passthrough: list[str]) -> int:
    """Delegate to scripts/e2e: a live happy-path sweep of every command tree.

    The harness skips gracefully (exit 0) when the target is not configured;
    pass --strict through to fail instead.
    """
    e2e = os.path.join(os.path.dirname(os.path.abspath(__file__)), "e2e")
    cmd = [e2e, *passthrough]
    print(f"test/e2e: running {os.path.relpath(e2e)} {' '.join(passthrough)}".rstrip())
    return subprocess.run(cmd).returncode


def run_lifecycle(verbose: bool, passthrough: list[str]) -> int:
    """Delegate to scripts/lifecycle: a destructive VM+CT lifecycle on an
    isolated SDN + pool. Skips gracefully (exit 0) when the target is not
    configured; pass --strict through to fail instead.
    """
    lc = os.path.join(os.path.dirname(os.path.abspath(__file__)), "lifecycle")
    cmd = [lc, *passthrough]
    print(f"test/lifecycle: running {os.path.relpath(lc)} {' '.join(passthrough)}".rstrip())
    return subprocess.run(cmd).returncode


TIERS = ("unit", "integration", "e2e", "lifecycle")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Run pve CLI tests by tier.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Tiers:\n"
            "  unit         Go unit tests for all packages (default)\n"
            "  integration  Integration tests gated on config/.env.test or PVE_TEST_* env\n"
            "  e2e          Live happy-path sweep of every command tree (scripts/e2e)\n"
            "  lifecycle    Destructive resource lifecycle (deferred)\n"
            "\n"
            "Extra args after the tier are forwarded to scripts/e2e, e.g.:\n"
            "  scripts/test e2e qemu cluster --target lab --strict\n"
        ),
    )
    parser.add_argument(
        "tier",
        nargs="?",
        default="unit",
        choices=TIERS,
        help="Test tier to run (default: unit)",
    )
    parser.add_argument("--race", action="store_true", help="Enable race detector (unit tier only)")
    parser.add_argument("--verbose", "-v", action="store_true", help="Pass -v to go test")
    args, extra = parser.parse_known_args()

    # The e2e and lifecycle tiers shell out to a non-go runner; they need `go`
    # only to build the binary, which those scripts handle themselves.
    if args.tier not in ("e2e", "lifecycle"):
        check_go()

    dispatch = {
        "unit": lambda: run_unit(args.race, args.verbose),
        "integration": lambda: run_integration(args.verbose),
        "e2e": lambda: run_e2e(args.verbose, extra),
        "lifecycle": lambda: run_lifecycle(args.verbose, extra),
    }

    rc = dispatch[args.tier]()
    sys.exit(rc)


if __name__ == "__main__":
    main()
