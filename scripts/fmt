#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""Format Go sources with gofmt; apply goimports if available."""

import argparse
import shutil
import subprocess
import sys


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def check_go() -> None:
    result = subprocess.run(["go", "version"], capture_output=True)
    if result.returncode != 0:
        die("'go' not found in PATH — install Go 1.26+")


def run_gofmt(check: bool, verbose: bool) -> int:
    if check:
        cmd = ["gofmt", "-l", "."]
        print("fmt/gofmt: checking formatting (gofmt -l .)")
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.stdout.strip():
            print("fmt/gofmt: unformatted files:")
            for line in result.stdout.strip().splitlines():
                print(f"  {line}")
            return 1
        print("fmt/gofmt: all files properly formatted")
        return 0
    cmd = ["gofmt", "-w", "."]
    if verbose:
        print("fmt/gofmt: formatting (gofmt -w .)")
    result = subprocess.run(cmd)
    return result.returncode


def run_goimports(check: bool, verbose: bool) -> int:
    if check:
        result = subprocess.run(
            ["goimports", "-l", "."],
            capture_output=True,
            text=True,
        )
        if result.stdout.strip():
            print("fmt/goimports: files needing import updates:")
            for line in result.stdout.strip().splitlines():
                print(f"  {line}")
            return 1
        return 0
    cmd = ["goimports", "-w", "."]
    if verbose:
        print("fmt/goimports: updating imports (goimports -w .)")
    result = subprocess.run(cmd)
    return result.returncode


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Format Go sources using gofmt and goimports (if available).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="Check formatting without writing; exit 1 if unformatted files exist",
    )
    parser.add_argument("--verbose", "-v", action="store_true", help="Verbose output")
    args = parser.parse_args()

    check_go()

    rc = run_gofmt(args.check, args.verbose)
    if rc != 0:
        sys.exit(rc)

    if shutil.which("goimports"):
        rc = run_goimports(args.check, args.verbose)
        if rc != 0:
            sys.exit(rc)
    else:
        if args.verbose:
            print("fmt: goimports not found — skipping import updates")
            print("  install: go install golang.org/x/tools/cmd/goimports@latest")

    if not args.check:
        print("fmt: ok")

    sys.exit(0)


if __name__ == "__main__":
    main()
